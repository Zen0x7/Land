{
  "name": "Land",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/land.cjs",
  "module": "./dist/land.js",
  "types": "./dist/land.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && rm -rf src/system/public/assets/admin && tsc -p tsconfig.system-admin.json && node scripts/copy-system-assets.mjs",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "cluster:three": "yarn build && node run-three-node-cluster.mjs"
  },
  "packageManager": "yarn@4.10.3",
  "dependencies": {
    "cron": "^4.4.0",
    "express": "^5.2.1",
    "pinia": "^3.0.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^2.0.0-alpha.12",
    "vitest": "^4.1.5"
  }
}
